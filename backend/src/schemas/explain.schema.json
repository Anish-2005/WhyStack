{
  "$id": "https://example.com/schemas/explain.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "logs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "time": { "type": "string" },
          "service": { "type": "string" },
          "message": { "type": "string" },
          "status": { "type": "integer" },
          "latency_ms": { "type": "number" },
          "cpu_percent": { "type": "number" },
          "memory_percent": { "type": "number" }
        },
        "additionalProperties": true
      },
      "minItems": 1
    }
  },
  "required": ["logs"],
  "additionalProperties": false
}
